{
    "name": "threejs-gem-game",
    "private": true,
    "version": "1.0.0",
    "description": "A 3D dungeon exploration game built with Three.js and React",
    "author": "ThreeJS Gem Game Developer",
    "main": "electron/main.js",
    "homepage": "./",
    "scripts": {
        "start": "vite",
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "electron": "electron .",
        "electron-dev": "concurrently \"yarn dev\" \"wait-on http://localhost:5173 && electron .\"",
        "electron-pack": "yarn build && electron-builder",
        "electron-dist": "yarn build && electron-builder --publish=never",
        "generate-config": "node scripts/generate-config.js",
        "scan-components": "npx ts-node src/utils/componentScanner.ts"
    },
    "dependencies": {
        "@react-three/drei": "^10.7.6",
        "@react-three/fiber": "^9.3.0",
        "@react-three/rapier": "^2.1.0",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "three": "^0.180.0",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.36.0",
        "@types/react": "^19.1.13",
        "@types/react-dom": "^19.1.9",
        "@types/three": "^0.180.0",
        "@vitejs/plugin-react": "^4.7.0",
        "concurrently": "^9.2.1",
        "electron": "^38.1.2",
        "electron-builder": "^26.0.12",
        "eslint": "^9.36.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.4.0",
        "terser": "^5.44.0",
        "ts-node": "^10.9.2",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.44.0",
        "vite": "^5.4.20",
        "wait-on": "^9.0.1"
    },
    "build": {
        "appId": "com.threejs.gem.game",
        "productName": "ThreeJS Gem Game",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "node_modules/**/*"
        ],
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "mac": {
            "target": "dmg",
            "icon": "public/favicon.ico"
        },
        "linux": {
            "target": "AppImage",
            "icon": "public/favicon.ico"
        }
    }
}